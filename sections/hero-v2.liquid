{{ 'hero-v2.css' | asset_url | stylesheet_tag }}
<div class="hero-v2-section page-width">
  <div class="">
    <div class="hero-wrapper">
      <div class="content-container">
        <h1>{{ section.settings.hero_heading }}</h1>
        <p>{{ section.settings.hero_subheading }}</p>
        <a href="{{ section.settings.hero_button_url }}" class="button">
          {{ section.settings.hero_button_text }}
        </a>  

        <div class="text-contents">
          <div class="tc tc-1">
            {{ section.settings.text_content_1 }}
            <p>{{ section.settings.text_subcontent_1 }}</p>
          </div>

          <div class="divider"></div>
          <div class="tc tc-2">
            {{ section.settings.text_content_2 }}
            <p>{{ section.settings.text_subcontent_2 }}</p>
          </div>
          <div class="divider hidden--mobile"></div>
          <div class="tc tc-3">
            {{ section.settings.text_content_3 }}
            <p>{{ section.settings.text_subcontent_3 }}</p>
          </div>
        </div>
      </div>
      <div class="image-container">
        {% if section.settings.hero_image != blank %}
          <img
            src="{{ section.settings.hero_image | image_url: width: 2000 }}"
            alt="{{ section.settings.hero_image.alt | escape }}"
            loading="lazy"
            class="hidden--mobile"
          >
        {% endif %}
        {% if section.settings.hero_image != blank %}
          <img
            src="{{ section.settings.hero_image | image_url: width: 2000 }}"
            alt="{{ section.settings.hero_image.alt | escape }}"
            loading="lazy"
            class="hidden--desktop"
          >
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% style %}

.hero-wrapper {
  background-color: {{ section.settings.hero_bg_color }}
}
.hero-v2-section {
  margin: auto;
  padding-top: {{ section.settings.hero_top_padding }}px;
  padding-bottom: {{ section.settings.hero_bot_padding }}px;
  max-width: 1400px;
  width: calc(100% - 40px);
}

{% endstyle %}


{%  schema  %}
{
  "name": "t:names.hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Hero Headings"
    },
    {
      "type": "richtext",
      "id": "hero_heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "hero_subheading",
      "label": "Sub Heading"
    },
    {
      "type": "richtext",
      "id": "hero_button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "hero_button_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Text Contents"
    },
    {
      "type": "textarea",
      "id": "text_content_1",
      "label": "Content 1"
    },
    {
      "type": "richtext",
      "id": "text_subcontent_1",
      "label": "Subcontent 1"
    },
    {
      "type": "textarea",
      "id": "text_content_2",
      "label": "Content 2"
    },
    {
      "type": "richtext",
      "id": "text_subcontent_2",
      "label": "Subcontent 2"
    },
    {
      "type": "textarea",
      "id": "text_content_3",
      "label": "Content 3"
    },
    {
      "type": "richtext",
      "id": "text_subcontent_3",
      "label": "Subcontent 3"
    },
    {
      "type": "header",
      "content": "Hero Media"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Featured Image"
    },
        {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Mobile Featured Image"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Background Color"
    },
    {
      "type": "header",
      "content": "Spacings"
    },
    {
      "type": "range",
      "id": "hero_top_padding",
      "label": "Section Top Padding (px)",
      "default": 50,
      "step": 2,
      "min": 0,
      "max": 150
    },
    {
      "type": "range",
      "id": "hero_bot_padding",
      "label": "Section Bottom Padding (px)",
      "default": 50,
      "step": 2,
      "min": 0,
      "max": 150
    }
  ],
  "presets": [
    {
      "name": "Hero V2",
      "category": "t:categories.banners"
    }
  ]
}


{% endschema %}